# --- Database ---
# Local dev: docker compose up -d  →  postgres://lmsource:lmsource@localhost:5433/lmsource
# On Render this is injected via render.yaml fromDatabase.
DATABASE_URL=postgres://lmsource:lmsource@localhost:5433/lmsource

# --- Auth (Better Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of the app (http://localhost:3000 in dev)
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# --- Email (Resend; password reset + verification). Empty in dev = links logged to console. ---
RESEND_API_KEY=
EMAIL_FROM=LMSource <onboarding@resend.dev>

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=
# Cheap/fast model for high-volume screening
LMSOURCE_MODEL_FAST=anthropic/claude-haiku-4.5
# Strong model for PICO, strategies, extraction, synthesis, verification
LMSOURCE_MODEL_STRONG=anthropic/claude-sonnet-5
# Optional per-stage overrides, e.g.:
# LMSOURCE_MODEL_EXTRACT=...
# LMSOURCE_MODEL_SYNTHESIZE=...

# --- Embeddings (OpenAI) ---
OPENAI_API_KEY=

# --- Source APIs ---
# Free instant key from https://www.ncbi.nlm.nih.gov/account/settings/ (raises PubMed limit 3→10 rps)
NCBI_API_KEY=
# Register at https://dev.elsevier.com — Scopus disabled (degraded mode) while empty
ELSEVIER_API_KEY=
ELSEVIER_INST_TOKEN=
# Contact email sent to OpenAlex (polite pool) and Crossref User-Agent
CONTACT_MAILTO=
